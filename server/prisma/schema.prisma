generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 使用者模型
model User {
  id            String    @id @default(cuid())
  name          String?
  password      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // 部門關聯 (一對多)
  departmentId String? // 第 1 步選擇的部門 ID
  department   Department? @relation(fields: [departmentId], references: [id])

  // 登入方式 (第 2 步判斷)
  provider AuthProvider @default(LOCAL) // LOCAL, GOOGLE, MICROSOFT

  googleId String? @unique
  // 權限角色：預設為一般員工 (USER)
  role     Role    @default(USER)
  status   Status  @default(PENDING) // 預設待審核

  // 關聯到第三方登入的帳戶 (NextAuth 必備)
  accounts Account[]
  sessions Session[]

  // 記錄是誰建立的專案 (選填)
  createdProjects Project[] @relation("ProjectCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique // 例如：開發部、業務部、人事部
  users     User[] // 關聯到該部門的所有員工
  createdAt DateTime @default(now())
}

// 角色列舉
enum Role {
  ADMIN // 管理員：可看專案金額、刪除專案
  USER // 一般員工：僅能查看或編輯部分內容
}

enum Status {
  ACTIVE // 已通過
  PENDING // 待審核
  SUSPENDED // 停權
}

enum AuthProvider {
  LOCAL // 訪客 (帳密)
  GOOGLE // Gmail
  MICROSOFT // Microsoft
}

model Client {
  id   String @id @default(cuid())
  name String @unique // 客戶名稱 (例如：國泰人壽)

  // 一個客戶可以有多個專案
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 專案模型
model Project {
  id        String @id @default(cuid())
  projectNo String @unique // 專案編號
  name      String // 專案名稱

  status    ProjectStatus @default(UNFILLED)
  // 關聯到 Client
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  // 建立者
  creatorId String
  creator   User          @relation("ProjectCreator", fields: [creatorId], references: [id])

  // 關聯到訂單 (一對一：一個專案對應一筆待處理訂單)
  order Order?

  // 關聯到採購單 (一對多：一個專案可能有多張採購單)
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 訂單模型 (管理員負責填寫金額)
model Order {
  id String @id @default(cuid())

  // 關聯專案
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 管理員填寫的欄位
  amount Float? // 金額 (初始為 null，等管理員填寫)
  status String @default("PENDING") // 狀態：PENDING (待填), COMPLETED (已完成)

  attachments Attachment[] // 一個專案可以有多個附件

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  invoices  Invoice[]
}

// 採購單模型 (員工負責)
model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique // 採購單號
  item     String // 品項
  // quantity Int 
  vendor   String // 供應廠商名稱
  amount   Float

  // 關聯專案
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  attachments      Attachment[] // 一個專案可以有多個附件
  remarks          PurchaseOrderRemark[]
  purchaseInvoices PurchaseInvoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderRemark {
  id       String  @id @default(cuid())
  content  String  @db.Text
  category String? // 例如：施工、材料、驗收（可選）

  // 🚀 外鍵關聯
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Attachment {
  id       String @id @default(cuid())
  fileName String // 原始檔名 (e.g., 採購清單_2026.xlsx)
  fileUrl  String // 檔案路徑
  fileType String // 格式：IMAGE, EXCEL, PDF

  // 關聯到訂單 (可選，因為有的附件可能是採購單的)
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // 關聯到採購單 (可選)
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// 以下為 NextAuth.js 支援第三方登入所需的標準模型
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Invoice {
  id        String @id @default(cuid())
  invoiceNo String @unique
  amount    Float // 最終收費金額 (包含階段款 + 額外費用)

  // 狀態與日期
  status  InvoiceStatus @default(PENDING)
  dueDate DateTime? // 👈 新增：繳款期限
  paidAt  DateTime? // 實際收款日

  // 關聯
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseInvoice {
  id              String        @id @default(cuid())
  amount          Float
  invoiceNo       String? // 供應商開給我們的號碼
  purchaseOrderId String        @unique
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
  status          String        @default("PENDING") // 我們付錢給供應商了沒
  createdAt       DateTime      @default(now())
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  UNFILLED // 未填寫：剛建立專案，尚未填寫任何採購單或金額
  FILLED // 已填寫：員工已填寫採購單，或初步資料已齊全
  COMPLETED // 完成：管理員已確認金額並結案
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

enum purchaseInvoiceStatus {
  PENDING
  PAID
  CANCELLED
}
