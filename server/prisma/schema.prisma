generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// 使用者模型
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // 權限角色：預設為一般員工 (USER)
  role Role @default(USER)

  // 關聯到第三方登入的帳戶 (NextAuth 必備)
  accounts Account[]
  sessions Session[]

  // 記錄是誰建立的專案 (選填)
  createdProjects Project[] @relation("ProjectCreator")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 角色列舉
enum Role {
  ADMIN // 管理員：可看專案金額、刪除專案
  USER // 一般員工：僅能查看或編輯部分內容
}

model Client {
  id   String @id @default(cuid())
  name String @unique // 客戶名稱 (例如：國泰人壽)

  // 一個客戶可以有多個專案
  projects Project[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 專案模型
model Project {
  id        String @id @default(cuid())
  projectNo String @unique // 專案編號
  name      String // 專案名稱

  status    ProjectStatus @default(UNFILLED)
  // 關聯到 Client
  clientId  String
  client    Client        @relation(fields: [clientId], references: [id])
  // 建立者
  creatorId String
  creator   User          @relation("ProjectCreator", fields: [creatorId], references: [id])

  // 關聯到訂單 (一對一：一個專案對應一筆待處理訂單)
  order Order?

  // 關聯到採購單 (一對多：一個專案可能有多張採購單)
  purchaseOrders PurchaseOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 訂單模型 (管理員負責填寫金額)
model Order {
  id String @id @default(cuid())

  // 關聯專案
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 管理員填寫的欄位
  amount Float? // 金額 (初始為 null，等管理員填寫)
  status String @default("PENDING") // 狀態：PENDING (待填), COMPLETED (已完成)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 採購單模型 (員工負責)
model PurchaseOrder {
  id       String @id @default(cuid())
  poNumber String @unique // 採購單號
  item     String // 品項
  quantity Int // 數量
  vendor   String // 供應廠商名稱
  amount   Float

  // 關聯專案
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 以下為 NextAuth.js 支援第三方登入所需的標準模型
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ProjectStatus {
  UNFILLED // 未填寫：剛建立專案，尚未填寫任何採購單或金額
  FILLED // 已填寫：員工已填寫採購單，或初步資料已齊全
  COMPLETED // 完成：管理員已確認金額並結案
}
